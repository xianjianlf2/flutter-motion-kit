{
  "name": "flutter-motion-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing verified Flutter animation implementations + pitfalls to AI coding assistants (Claude Code, Cursor).",
  "keywords": ["mcp", "modelcontextprotocol", "flutter", "animation", "claude", "cursor", "ai"],
  "license": "MIT",
  "author": "MarkXian <mark-xian@foxmail.com>",
  "homepage": "https://github.com/xianjianlf2/flutter-motion-kit",
  "repository": { "type": "git", "url": "https://github.com/xianjianlf2/flutter-motion-kit.git", "directory": "mcp" },
  "type": "module",
  "bin": { "flutter-motion-mcp": "dist/index.js" },
  "files": ["dist", "catalog.json", "README.md"],
  "scripts": {
    "prebuild": "node ../scripts/build-catalog.mjs && cp ../catalog.json ./catalog.json",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
