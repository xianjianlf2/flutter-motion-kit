---
import '../styles/global.css';
const { title = 'Flutter Motion Kit' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="可预览的 Flutter 动画实现集合 + 对应的坑，支持 Claude Code 一键复用（MCP）。" />
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <h1><a href="/">Flutter Motion Kit</a></h1>
        <span class="tag">可预览的 Flutter 动画 + 避坑指南 · 支持 Claude Code 一键复用</span>
      </header>
      <slot />
    </div>
  </body>
</html>
