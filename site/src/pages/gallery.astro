---
import Base from '../layouts/Base.astro';
import catalog from '../../../catalog.json';

const { entries, categories } = catalog;
// The real URL lives in site/.env's PUBLIC_MCP_ORIGIN (not committed); this is just a placeholder fallback.
const MCP_ORIGIN = import.meta.env.PUBLIC_MCP_ORIGIN ?? 'https://flutter-motion-kit.YOUR_SUBDOMAIN.workers.dev';
const cursorConfig = Buffer.from(JSON.stringify({ url: `${MCP_ORIGIN}/mcp` })).toString('base64');
---

<Base title="Verified catalog — Flutter Motion Kit">
  <p style="color:var(--muted);max-width:680px">
    The verified catalog: every animation runs live in the browser (real Flutter web, not a
    screen recording), ships copy-paste code, and is annotated with
    <strong>its pitfalls (with sources and confidence)</strong>. Search and reuse them straight
    from Claude Code / Cursor via MCP.
  </p>

  <div class="connect">
    <strong>One-click into your AI editor</strong>
    <span class="live" id="live"></span>
    <div class="btnrow">
      <a class="act primary" href={`cursor://anysphere.cursor-deeplink/mcp/install?name=flutter-motion&config=${cursorConfig}`}>Add to Cursor</a>
      <a class="act" href={`https://insiders.vscode.dev/redirect/mcp/install?name=flutter-motion&config=${encodeURIComponent(JSON.stringify({ url: `${MCP_ORIGIN}/mcp` }))}`}>Add to VS Code</a>
      <button class="act" id="copy-cc">Copy Claude Code command</button>
    </div>
    <code id="cc-cmd" style="display:block;margin-top:8px;font-size:12px;color:var(--muted)">claude mcp add --transport http flutter-motion {MCP_ORIGIN}/mcp</code>
  </div>

  <a class="playground-cta" href="/">
    <span class="pg-icon">▶︎</span>
    <span>
      <strong>Open the interactive Playground</strong>
      <span class="pg-sub">Drag sliders for live tweaks · code highlights in sync · covers all 6 categories</span>
    </span>
    <span class="pg-arrow">→</span>
  </a>

  <div class="filters" id="filters">
    <span class="chip" data-cat="all" aria-pressed="true">all</span>
    {categories.map((c) => <span class="chip" data-cat={c} aria-pressed="false">{c}</span>)}
  </div>

  <div class="grid" id="grid">
    {entries.map((e) => (
      <a class="card" href={`/a/${e.id}`} data-cat={e.category}>
        <h3>{e.title}</h3>
        <p>{e.summary}</p>
        <div class="badges">
          <span class="badge">{e.category}</span>
          <span class="badge">difficulty {e.difficulty}/5</span>
          <span class="badge">⚠ {e.pitfalls.length} pitfalls</span>
        </div>
      </a>
    ))}
  </div>

  <script>
    const chips = document.querySelectorAll('#filters .chip');
    const cards = document.querySelectorAll('#grid .card');
    chips.forEach((chip) =>
      chip.addEventListener('click', () => {
        const cat = chip.getAttribute('data-cat');
        chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
        cards.forEach((card) => {
          const show = cat === 'all' || card.getAttribute('data-cat') === cat;
          (card as HTMLElement).style.display = show ? '' : 'none';
        });
      }),
    );

    // Copy the Claude Code connect command
    const ccBtn = document.getElementById('copy-cc');
    ccBtn?.addEventListener('click', () => {
      const cmd = document.getElementById('cc-cmd')?.textContent ?? '';
      navigator.clipboard.writeText(cmd.trim()).then(() => {
        const o = ccBtn.textContent;
        ccBtn.textContent = '✓ Copied';
        setTimeout(() => (ccBtn.textContent = o), 1400);
      });
    });

  </script>

  <!-- Live connection count: mcpOrigin is injected at build time (from site/.env); silently hidden on failure -->
  <script define:vars={{ mcpOrigin: MCP_ORIGIN }}>
    fetch(`${mcpOrigin}/stats`)
      .then((r) => r.json())
      .then((d) => {
        const el = document.getElementById('live');
        if (el && typeof d.connections === 'number') {
          el.textContent = `· ${d.connections} developers connected`;
        }
      })
      .catch(() => {});
  </script>
</Base>
