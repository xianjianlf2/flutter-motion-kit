---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../../layouts/Base.astro';
import catalog from '../../../../catalog.json';

export function getStaticPaths() {
  return catalog.entries.map((e) => ({ params: { id: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;

// Self-hosted preview: scripts/build-previews.mjs compiles main.dart into runnable Flutter web
// under site/public/preview/<id>/. If present, embed it directly — no DartPad / gist / token needed.
const previewPath = fileURLToPath(new URL(`../../../public/preview/${entry.id}/index.html`, import.meta.url));
const hasPreview = existsSync(previewPath);
const previewUrl = `/preview/${entry.id}/`;

// Ready-made "Copy for AI" prompt: code + pitfalls, so CC/Cursor land it with the gotchas in mind.
const aiPrompt = [
  `Add this "${entry.title}" animation to my Flutter project.`,
  '',
  'Code:',
  '```dart',
  entry.code.trim(),
  '```',
  '',
  'Be sure to follow these pitfalls:',
  ...entry.pitfalls.map((p, i) => `${i + 1}. ${p.claim} — ${p.fix}`),
  '',
  `(Verified on ${entry.verifiedOn})`,
].join('\n');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: `${entry.title} — Flutter animation implementation & pitfalls`,
  description: entry.summary.trim(),
  about: 'Flutter animation',
  keywords: ['Flutter', 'animation', entry.category, ...(entry.tags ?? [])].join(', '),
  proficiencyLevel: entry.difficulty <= 2 ? 'Beginner' : 'Expert',
  url: new URL(`/a/${entry.id}`, Astro.site).href,
};
---

<Base
  title={`${entry.title} — Flutter Motion Kit`}
  description={`${entry.summary.trim()} ${entry.pitfalls.length} pitfalls included — preview it live and reuse in one click.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <p><a href="/">← Back</a></p>
  <h2 style="margin-bottom:4px">{entry.title}</h2>
  <p class="verified">{entry.category} · difficulty {entry.difficulty}/5 · verified {entry.verifiedOn}</p>
  <p style="color:var(--muted)">{entry.summary}</p>

  {hasPreview ? (
    <div class="preview-wrap">
      <div class="preview-bar">
        <span>▶︎ Running for real ({entry.verifiedOn.split('/')[0].trim()} · self-hosted, not a recording)</span>
        <button class="act tiny" id="replay" title="Reload and replay from the start">↻ Replay</button>
      </div>
      <iframe class="dartpad" id="preview" src={previewUrl} title={`${entry.title} preview`} loading="lazy"></iframe>
    </div>
  ) : entry.dartpadUrl ? (
    <iframe class="dartpad" src={entry.dartpadUrl} title="DartPad preview" loading="lazy"></iframe>
  ) : (
    <p style="color:var(--warn)">⏳ Live preview not ready: run <code>node scripts/build-previews.mjs</code> to generate the self-hosted preview, then it embeds here.</p>
  )}

  <div class="btnrow">
    <button class="act primary" id="copy-ai">📋 Copy for AI (code + pitfalls)</button>
    <button class="act" id="copy-code">Copy code</button>
  </div>

  <h3>Code</h3>
  <pre><code>{entry.code.trim()}</code></pre>

  <h3>⚠️ Pitfalls ({entry.pitfalls.length})</h3>
  {entry.pitfalls.map((p) => (
    <div class="pitfall">
      <div>{p.claim}</div>
      <div class="fix">✅ {p.fix}</div>
      <div class="src">
        <span class="conf">{p.confidence}</span>
        {p.source?.startsWith('http') ? <> · <a href={p.source} target="_blank" rel="noopener">source</a></> : null}
        {p.provenBy ? <> · proven by test: <code>{p.provenBy}</code></> : null}
      </div>
    </div>
  ))}

  {entry.docs?.length ? (
    <>
      <h3>Official docs</h3>
      <ul>{entry.docs.map((d) => <li><a href={d} target="_blank" rel="noopener">{d}</a></li>)}</ul>
    </>
  ) : null}

  <script type="application/json" id="payload" set:html={JSON.stringify({ code: entry.code, prompt: aiPrompt })} />
  <script>
    const data = JSON.parse(document.getElementById('payload').textContent);
    const flash = (btn, txt) => { const o = btn.textContent; btn.textContent = txt; setTimeout(() => (btn.textContent = o), 1400); };
    document.getElementById('copy-code').addEventListener('click', (e) => {
      navigator.clipboard.writeText(data.code).then(() => flash(e.target, '✓ Code copied'));
    });
    document.getElementById('copy-ai').addEventListener('click', (e) => {
      navigator.clipboard.writeText(data.prompt).then(() => flash(e.target, '✓ Copied — paste into Claude Code'));
    });
    // Replay: reload the iframe so the animation runs again from its initial state
    const replay = document.getElementById('replay');
    const preview = document.getElementById('preview');
    if (replay && preview) replay.addEventListener('click', () => { preview.src = preview.src; });
  </script>
</Base>
