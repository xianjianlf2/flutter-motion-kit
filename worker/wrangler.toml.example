# Copy to a local wrangler.toml and fill in the real values (wrangler.toml is gitignored, never committed).
#   cp wrangler.toml.example wrangler.toml
name = "flutter-motion-kit"
main = "src/index.ts"
compatibility_date = "2024-11-01"

# Account-specific identifiers stay only in your local wrangler.toml, never committed:
# account_id = "<optional; usually omittable once logged in>"

# KV (connection counter). After creating it, paste the id here:
#   npx wrangler kv namespace create STATS
#   npx wrangler kv namespace create STATS --preview
[[kv_namespaces]]
binding = "STATS"
id = "<your-kv-id>"
preview_id = "<your-preview-kv-id>"

# To hide your *.workers.dev account subdomain, bind a custom domain (recommended):
# routes = [{ pattern = "mcp.yourdomain.com", custom_domain = true }]
